# autonomon device environment variables
# Copy to .env.device: cp .env.device.example .env.device
# .env.device is gitignored — never commit secrets or credentials here.

# =============================================================================
# Deployment (scripts/deploy.sh)
# =============================================================================

# SSH target for the Raspberry Pi — "user@hostname" or plain IP.
# Required for remote deployment.
# NOMON_PI_HOST=pi@raspberrypi.local
NOMON_PI_HOST=

# Optional path to an SSH private key.
# NOMON_SSH_KEY=~/.ssh/id_ed25519
NOMON_SSH_KEY=

# Optional sudo password for non-interactive remote sudo.
# Leave empty to use interactive sudo prompts.
# NOMON_SUDO_PASS='replace_with_pi_user_password'
NOMON_SUDO_PASS=

# Optional absolute path to the autonomon repo on the remote Pi.
# Default: ${HOME}/perceptua-nomon/autonomon
# NOMON_REMOTE_DIR=/home/pi/perceptua-nomon/autonomon

# Absolute path of the routine catalogue autonomon publishes at deploy time for
# nomothetic to read (it lists and launches routines from this file; the two
# services keep separate venvs and never import each other — see ADR-005).
# MUST match NOMON_ROUTINE_CATALOG_PATH in nomothetic/.env.device.
NOMON_ROUTINE_CATALOG_PATH=/var/lib/nomon/routine_catalog.json

# Service user that owns the plugin key on the Pi.
# Overrides the value read from /etc/nomothetic/nomothetic.env.
# Default: nomon
# NOMON_SERVICE_USER=nomon

# =============================================================================
# Plugin Runtime
# On the Pi these vars are written to /etc/autonomon/autonomon.env by
# deploy.sh. Set them here for local dev / manual testing only.
# =============================================================================

# Base URL of the device's nomothetic REST API.
# Required when running the plugin manually (not via deploy.sh).
# NOMON_DEVICE_URL=https://raspberrypi.local:8443
NOMON_DEVICE_URL=

# Path to the Ed25519 private key used for device JWT auth (ADR-019).
# On the Pi: /etc/autonomon/plugin.key (written by deploy.sh).
# For local dev: point at a key generated with:
#   python -m autonomon.plugin_auth generate-key ./plugin.key
# NOMON_PLUGIN_KEY=/etc/autonomon/plugin.key
NOMON_PLUGIN_KEY=

# Plugin name registered with nomothetic.
# Default: autonomon
# NOMON_PLUGIN_NAME=autonomon

# Device identifier stamped on pipeline messages.
# Default: nomon
# NOMON_DEVICE_ID=nomon

# Static bearer token — fallback when NOMON_PLUGIN_KEY is not set.
# Useful for quick dev/testing; key-based auth is preferred in production.
# NOMON_PLUGIN_TOKEN=

# JSON object of routine parameters passed to the plugin.
# Selects the routine via a "routine" key; remaining keys are routine-specific.
# Example: NOMON_PLUGIN_PARAMS='{"routine":"explore","obstacle_threshold_cm":25}'
# NOMON_PLUGIN_PARAMS={"routine":"explore"}
NOMON_PLUGIN_PARAMS=

# =============================================================================
# Vision (follow-user routine)
# Autonomon owns its vision config (ADR-004/005): deploy.sh writes these into
# /etc/autonomon/autonomon.env and the nomon-autonomon CLI loads them at startup.
# nomothetic never sees them.
# =============================================================================

# Person-detector backend for follow-user:
#   yolo-onnx   YOLOv8n via onnxruntime — most accurate; installs the 'vision'
#               extra and auto-fetches yolov8n.onnx on deploy (a slow download).
#   opencv-dnn  MobileNet-SSD via cv2.dnn — robust and light; installs the
#               'vision-opencv' extra and auto-fetches a ~23MB model. Recommended
#               OpenCV option.
#   opencv-hog  OpenCV HOG+SVM — NO model file, lightest, but brittle (fires on
#               architectural edges). Last resort.
#   fake        No-op detector (never detects). For smoke-testing the pipeline.
# Default: yolo-onnx
# NOMON_VISION_DETECTOR=opencv-dnn

# Detector weights. Leave unset to have deploy.sh auto-fetch to /var/lib/nomon/models:
#   yolo-onnx  → yolov8n.onnx
#   opencv-dnn → MobileNetSSD_deploy.caffemodel (+ prototxt below)
# NOMON_VISION_MODEL_PATH=/var/lib/nomon/models/MobileNetSSD_deploy.caffemodel

# MobileNet-SSD network definition (opencv-dnn only). Auto-fetched alongside the
# model when unset.
# NOMON_VISION_MODEL_CONFIG=/var/lib/nomon/models/MobileNetSSD_deploy.prototxt

# Plugin log level: DEBUG | INFO | WARNING | ERROR. Written to
# /etc/autonomon/autonomon.env on deploy; the nomon-autonomon CLI reads it and
# falls back to WARNING when unset. Set DEBUG to trace per-frame detections and
# planner decisions in the gateway journal when diagnosing in the field.
# Default: WARNING
# NOMON_LOG_LEVEL=DEBUG
